# Email (Gmail SMTP)
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_TO="your-email@gmail.com"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"

# GitHub OAuth
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"
ALLOWED_GITHUB_EMAILS="your-email@example.com,other@example.com"

# Git Operations (for content commits)
GITHUB_PAT="your-github-personal-access-token"
GITHUB_USERNAME="your-github-username"
GITHUB_REPO_OWNER="repo-owner"
GITHUB_REPO_SLUG="repo-name"
GIT_USER_NAME="Admin Panel"
GIT_USER_EMAIL="admin@example.com"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Analytics
NEXT_PUBLIC_YANDEX_METRIKA_ID="your-yandex-metrika-id"
NEXT_PUBLIC_GA_ID="your-google-analytics-id"
